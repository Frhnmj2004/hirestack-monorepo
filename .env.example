# hirelens – copy to .env or backend/.env.local and fill in values

# Database (single shared PostgreSQL)
DATABASE_URL=postgresql://hirelens:hirelens@localhost:5432/hirelens

# Redis
REDIS_URL=redis://localhost:6379

# NATS
NATS_URL=nats://localhost:4222

# LiveKit (for livekit-agent service)
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# assist-service (human interview copilot)
DEEPGRAM_API_KEY=
OPENAI_API_KEY=
OPENAI_ANALYSIS_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Optional: Simli / OpenAI / Deepgram (for livekit-agent)
# SIMLI_API_KEY=
# SIMLI_FACE_ID=
