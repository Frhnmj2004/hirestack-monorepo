# hirelens – copy to .env or backend/.env.local and fill in values

# Database (single shared PostgreSQL)
DATABASE_URL=postgresql://hirelens:hirelens@localhost:5432/hirelens

# Redis
REDIS_URL=redis://localhost:6379

# NATS
NATS_URL=nats://localhost:4222

# LiveKit (for livekit-agent service)
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Optional: Simli / OpenAI / Deepgram (for AI interviewer agent)
# SIMLI_API_KEY=
# SIMLI_FACE_ID=
# OPENAI_API_KEY=
# DEEPGRAM_API_KEY=
