{
  "manifest_version": 3,
  "name": "HireLens Interview Copilot",
  "version": "1.0.0",
  "description": "AI-powered interview copilot — follow-ups, resume alerts, and structured questions for any video call",
  "permissions": [
    "storage",
    "scripting",
    "activeTab",
    "tabs",
    "windows",
    "tabCapture",
    "offscreen"
  ],
  "host_permissions": [
    "https://meet.google.com/*",
    "https://app.zoom.us/*",
    "https://*.zoom.us/*",
    "https://teams.microsoft.com/*",
    "https://*.webex.com/*",
    "http://localhost/*",
    "http://127.0.0.1/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "HireLens"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://meet.google.com/*",
        "https://app.zoom.us/*",
        "https://*.zoom.us/wc/*",
        "https://teams.microsoft.com/*",
        "https://*.webex.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["content.css", "audio-worklet-processor.js"],
      "matches": ["<all_urls>"]
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
